.mypy_cache/
.dmypy.json
dmypy.json

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Docker
*.dockerignore

# Data (generated)
data/samples/*.csv
!data/samples/generate_seed_data.py

# Notebooks checkpoints
.ipynb_checkpoints/

# Logs
*.log
logs/
