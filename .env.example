# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=dq_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=dq_db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://dq_user:change_me_in_production@localhost:5432/dq_db
LOG_LEVEL=INFO
DEBUG=false

# API
API_PORT=8000

# Simulation defaults
DEFAULT_N_SIMULATIONS=10000
QUALITY_THRESHOLD=0.8
